########################################################################
# SECTION::SOURCE MAIN BASHRC
########################################################################
if [ -f /etc/bashrc ]; then
  . /etc/bashrc
fi

########################################################################
# SECTION::MODIFY USER PATH ENV
########################################################################
if ! [[ "$PATH" =~ "$HOME/bin:" ]]; then
  PATH="$HOME/bin:$PATH"
fi

export PATH

########################################################################
# SECTION::SOURCE BASHRC FILES
########################################################################
if [ -d ~/.bashrc.d ]; then
  for rc in ~/.bashrc.d/*; do
    if [ -f "$rc" ]; then
        . "$rc"
    fi
  done
fi

unset rc

########################################################################
# SECTION::CUSTOM ALIASES
########################################################################
alias grep='grep --color=auto'
alias ls='ls --color=auto'
alias rm='rm -i'
alias vi='vim'

########################################################################
# SECTION::TERMINAL CUSTOMIZATIONS
########################################################################
PS1="[\[\e[38;5;221m\]\u\[\e[0m\]@\[\e[38;5;112m\]\H\[\e[0m\]]:\[\e[38;5;196m\]\w\[\e[0m\] \$ "

########################################################################
# SECTION::CUSTOM ENV RE-EXPORTS
########################################################################
export GREP_COLORS='ms=38;5;221:mc=38;5;221:fn=38;5;112:ln=38;5;208:se=38;5;117:'
export LS_COLORS='fi=38;5;145:di=38;5;37:ln=38;5;135:pi=38;5;208:bd=48;5;238;38;5;220:cd=48;5;238;38;5;215:or=38;5;196:'
